# --- dependencies / build output ---
node_modules/
dist/

# --- wrangler local state (R2/D1 emulator data, sessions, caches) ---
.wrangler/

# --- secrets ---
.env
.env.cloudflare
.dev.vars

# --- one-off debug artifacts (may contain real workbook rows) ---
# `npm run dev` against the /api/debug/scrape endpoint dumps a JSON of the
# latest workbook's parsed rows here. Real asset IDs / shop names — never
# commit unless explicitly intended.
debug-scrape.json
debug-*.json
*.scrape.json

# --- editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS noise ---
.DS_Store
Thumbs.db

# --- npm/yarn debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- coverage ---
coverage/
*.lcov

# --- Excel / Office temp files (open workbook artifacts) ---
~$*.xlsx
~$*.xlsm

# --- workspace zips / scratch ---
*.zip
scratch/
tmp/

# One-off local scraper deps (run npm install inside the folder)
scripts/pats-waiver-scrape/node_modules/
